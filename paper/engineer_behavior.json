    {
      "module": "Th2_GATA3",
      "hash": "e883edb1e4",
      "proposals": [
        {
          "module": "Th2_GATA3",
          "run": 0,
          "kind": "propose",
          "rationale": "GATA3 serves as the Th2 hub\u2014driven by IL4/STAT6 autocrine signaling and cross-repressing the Th1 factors TBX21/STAT4\u2014so I wire a connected antagonistic circuit with mostly single additive terms."
        },
        {
          "module": "Th2_GATA3",
          "run": 1,
          "kind": "propose",
          "rationale": "I encode the canonical Th2 GATA3 core (STAT6\u2192GATA3 with GATA3 autoactivation driving IL4/IL5/IL13, IL4\u2192STAT6 feedback) coupled to the Th1 STAT4/TBX21 arm through mutual cross-antagonism, using separate additive terms to represent opposing activator/repressor inputs."
        },
        {
          "module": "Th2_GATA3",
          "run": 1,
          "kind": "repair",
          "rationale": "Add a direct activating edge from TBX21 to IL4 as a third additive term, since TBX21 knockdown reduces IL4 (a missing effect not explained by the current indirect repression path)."
        }
      ],
